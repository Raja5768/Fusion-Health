APP_NAME=Fusion Health
APP_ENV=local
DATABASE_URL=sqlite:///./fusion_health.db
SECRET_KEY=change-me-to-a-long-random-string
FUSION_ENCRYPTION_KEY=

WHOOP_CLIENT_ID=
WHOOP_CLIENT_SECRET=
WHOOP_REDIRECT_URI=http://localhost:8000/api/v1/auth/whoop/callback
WHOOP_SCOPES=offline read:profile read:recovery read:cycles read:sleep read:workout

OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1
ENABLE_OLLAMA=false
